<div class="col-lg-3 col-md-6 col-sm-6 wow fadeInUp" data-wow-delay="{{ item.delay }}s" data-wow-duration="1s">
  <div class="td-service-process-item {{ item.extraClass }}">
    <span class="icons mb-60 d-flex align-items-start justify-content-between">
      {% include item.icon %}
      <span class="number">{{ item.number }}</span>
    </span>
    <h5 class="title mb-15">{{ item.title }}</h5>
    <p class="para">{{ item.text }}</p>
  </div>
</div>